---
import MainLayout from '../layouts/MainLayout.astro';
import { formatDate } from '../lib/utils';
import { getActivePet } from '../lib/pet';
import { uploadPetPhoto } from '../lib/storage';

const { supabase, user, activePetId } = Astro.locals;
const { pet } = await getActivePet(supabase, user.id, activePetId);
if (!pet) return Astro.redirect('/perfil?new=1');

if (Astro.request.method === 'POST') {
  const formData = await Astro.request.formData();
  const action = formData.get('_action') as string;

  if (action === 'add') {
    const photo_url = await uploadPetPhoto(formData.get('photo') as File, user.id, supabase, 'adventures');
    await supabase.from('adventures').insert({
      pet_id: pet.id,
      title: formData.get('title') as string,
      description: (formData.get('description') as string) || null,
      date: formData.get('date') as string,
      location: (formData.get('location') as string) || null,
      photo_url,
    });
    return Astro.redirect('/aventuras?saved=1');
  }

  if (action === 'edit') {
    const adventureId = formData.get('adventure_id') as string;
    const updateData: Record<string, unknown> = {
      title: formData.get('title') as string,
      description: (formData.get('description') as string) || null,
      date: formData.get('date') as string,
      location: (formData.get('location') as string) || null,
    };
    const newPhotoUrl = await uploadPetPhoto(formData.get('photo') as File, user.id, supabase, 'adventures');
    if (newPhotoUrl) updateData.photo_url = newPhotoUrl;
    await supabase.from('adventures').update(updateData).eq('id', adventureId);
    return Astro.redirect('/aventuras?saved=1');
  }

  if (action === 'delete') {
    const adventureId = formData.get('adventure_id') as string;
    await supabase.from('adventures').delete().eq('id', adventureId);
    return Astro.redirect('/aventuras?deleted=1');
  }

  return Astro.redirect('/aventuras?saved=1');
}

const { data: adventures } = await supabase
  .from('adventures')
  .select('*')
  .eq('pet_id', pet.id)
  .order('date', { ascending: false });

const total = adventures?.length ?? 0;
const withPhotos = (adventures ?? []).filter(a => a.photo_url).length;
const locations = new Set((adventures ?? []).filter(a => a.location).map(a => a.location));
const showForm = Astro.url.searchParams.get('new') === '1';
---

<MainLayout title="Aventuras">

  {/* ── HEADER ── */}
  <div class="flex items-center justify-between mb-5 animate-fade-up">
    <div>
      <h1 class="text-xl font-black text-ink">Aventuras</h1>
      <p class="text-xs text-muted mt-0.5">Álbum de momentos de {pet.name}</p>
    </div>
    <a href="/aventuras?new=1" class="flex items-center gap-1.5 rounded-xl bg-accent px-3.5 py-2 text-xs font-semibold text-white hover:bg-accent-dark transition-colors active:scale-95">
      <svg class="h-3.5 w-3.5" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5"><path d="M12 5v14M5 12h14"/></svg>
      Nueva
    </a>
  </div>

  {/* ── STATS ── */}
  {total > 0 && (
    <div class="grid grid-cols-3 gap-3 mb-5 animate-fade-up">
      <div class="rounded-2xl bg-card border border-card-border px-4 py-3 text-center">
        <p class="text-lg font-black text-ink">{total}</p>
        <p class="text-[10px] text-muted font-medium mt-0.5">aventuras</p>
      </div>
      <div class="rounded-2xl bg-card border border-card-border px-4 py-3 text-center">
        <p class="text-lg font-black text-ink">{withPhotos}</p>
        <p class="text-[10px] text-muted font-medium mt-0.5">fotos</p>
      </div>
      <div class="rounded-2xl bg-card border border-card-border px-4 py-3 text-center">
        <p class="text-lg font-black text-ink">{locations.size}</p>
        <p class="text-[10px] text-muted font-medium mt-0.5">lugares</p>
      </div>
    </div>
  )}

  {/* ── ADD FORM (collapsible) ── */}
  {showForm && (
    <div class="mb-5 animate-fade-up" id="add-adventure-form">
      <div class="rounded-2xl bg-card border border-card-border p-5">
        <div class="flex items-center justify-between mb-4">
          <p class="text-sm font-bold text-ink">Nueva aventura</p>
          <a href="/aventuras" class="text-xs text-muted hover:text-ink transition-colors">Cancelar</a>
        </div>
        <form method="POST" enctype="multipart/form-data" class="space-y-3">
          <input type="hidden" name="_action" value="add" />
          <div>
            <label class="block text-xs font-medium text-muted mb-1">Título *</label>
            <input type="text" name="title" required placeholder="Ej: Día en la playa" class="w-full rounded-xl border border-card-border bg-canvas px-3 py-2.5 text-sm text-ink focus:outline-none focus:border-accent transition-colors" />
          </div>
          <div class="grid grid-cols-2 gap-3">
            <div>
              <label class="block text-xs font-medium text-muted mb-1">Fecha *</label>
              <input type="date" name="date" required class="w-full rounded-xl border border-card-border bg-canvas px-3 py-2.5 text-sm text-ink focus:outline-none focus:border-accent transition-colors" />
            </div>
            <div>
              <label class="block text-xs font-medium text-muted mb-1">Lugar</label>
              <input type="text" name="location" placeholder="Ej: Parque" class="w-full rounded-xl border border-card-border bg-canvas px-3 py-2.5 text-sm text-ink focus:outline-none focus:border-accent transition-colors" />
            </div>
          </div>
          <div>
            <label class="block text-xs font-medium text-muted mb-1">Descripción</label>
            <textarea name="description" rows="2" placeholder="¿Qué hicieron?" class="w-full rounded-xl border border-card-border bg-canvas px-3 py-2.5 text-sm text-ink focus:outline-none focus:border-accent transition-colors resize-none"></textarea>
          </div>
          <div>
            <label class="block text-xs font-medium text-muted mb-1">Foto</label>
            <input type="file" name="photo" accept="image/*" class="w-full rounded-xl border border-card-border bg-canvas px-3 py-2.5 text-sm text-ink file:mr-3 file:rounded-lg file:border-0 file:bg-accent/10 file:px-3 file:py-1 file:text-xs file:font-medium file:text-accent focus:outline-none" />
          </div>
          <button type="submit" class="w-full rounded-xl bg-accent text-white font-semibold py-2.5 text-sm hover:bg-accent-dark transition-colors active:scale-95">
            Guardar aventura
          </button>
        </form>
      </div>
    </div>
  )}

  {/* ── EMPTY STATE ── */}
  {total === 0 && !showForm && (
    <div class="rounded-2xl bg-card border border-dashed border-card-border p-8 text-center animate-fade-up">
      <div class="flex h-14 w-14 items-center justify-center rounded-2xl bg-accent/10 mx-auto mb-4">
        <svg class="h-7 w-7 text-accent" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5">
          <rect x="3" y="3" width="18" height="18" rx="2" ry="2"/><circle cx="8.5" cy="8.5" r="1.5"/><polyline points="21 15 16 10 5 21"/>
        </svg>
      </div>
      <p class="text-sm font-semibold text-ink mb-1">Sin aventuras registradas</p>
      <p class="text-xs text-muted mb-4">Registra el primer momento especial de {pet.name}</p>
      <a href="/aventuras?new=1" class="inline-flex items-center gap-1.5 rounded-xl bg-accent px-4 py-2.5 text-xs font-semibold text-white hover:bg-accent-dark transition-colors active:scale-95">
        <svg class="h-3.5 w-3.5" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5"><path d="M12 5v14M5 12h14"/></svg>
        Nueva aventura
      </a>
    </div>
  )}

  {/* ── PHOTO GRID (Instagram style) ── */}
  {total > 0 && (
    <div class="animate-fade-up">
      <div class="grid grid-cols-3 gap-1 rounded-2xl overflow-hidden">
        {(adventures ?? []).map((adv, i) => (
          <button
            type="button"
            class:list={[
              'lightbox-trigger relative aspect-square overflow-hidden bg-canvas group',
              i === 0 && total >= 3 && 'col-span-2 row-span-2'
            ]}
            data-id={adv.id}
            data-src={adv.photo_url || ''}
            data-title={adv.title}
            data-date={adv.date}
            data-location={adv.location || ''}
            data-description={adv.description || ''}
          >
            {adv.photo_url ? (
              <img src={adv.photo_url} alt={adv.title} class="h-full w-full object-cover transition-transform duration-300 group-hover:scale-105" loading="lazy" />
            ) : (
              <div class="h-full w-full flex items-center justify-center bg-accent/5">
                <svg class="h-8 w-8 text-accent/30" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5">
                  <rect x="3" y="3" width="18" height="18" rx="2" ry="2"/><circle cx="8.5" cy="8.5" r="1.5"/><polyline points="21 15 16 10 5 21"/>
                </svg>
              </div>
            )}
            {/* Overlay on hover */}
            <div class="absolute inset-0 bg-black/0 group-hover:bg-black/40 transition-colors flex items-end">
              <div class="w-full px-2 py-1.5 opacity-0 group-hover:opacity-100 transition-opacity">
                <p class="text-white text-[10px] font-semibold truncate">{adv.title}</p>
                <p class="text-white/70 text-[9px] truncate">{formatDate(adv.date)}{adv.location ? ` · ${adv.location}` : ''}</p>
              </div>
            </div>
          </button>
        ))}
      </div>
    </div>
  )}

  {/* ── TIMELINE LIST (below grid) ── */}
  {total > 0 && (
    <div class="mt-5 animate-fade-up">
      <p class="text-xs font-semibold text-muted uppercase tracking-widest mb-3">Todas las aventuras</p>
      <div class="rounded-2xl bg-card border border-card-border divide-y divide-card-border overflow-hidden">
        {(adventures ?? []).map((adv) => (
          <div class="adv-item">
            {/* View mode */}
            <div class="item-view flex items-center gap-3 px-4 py-3" data-id={adv.id}>
              {adv.photo_url ? (
                <img src={adv.photo_url} alt={adv.title} class="h-10 w-10 shrink-0 rounded-xl object-cover" loading="lazy" />
              ) : (
                <div class="h-10 w-10 shrink-0 rounded-xl bg-accent/5 flex items-center justify-center">
                  <svg class="h-5 w-5 text-accent/30" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5">
                    <rect x="3" y="3" width="18" height="18" rx="2" ry="2"/><circle cx="8.5" cy="8.5" r="1.5"/><polyline points="21 15 16 10 5 21"/>
                  </svg>
                </div>
              )}
              <div class="flex-1 min-w-0">
                <p class="text-sm font-semibold text-ink truncate">{adv.title}</p>
                <p class="text-[11px] text-muted">{formatDate(adv.date)}{adv.location ? ` · ${adv.location}` : ''}</p>
                {adv.description && <p class="text-[11px] text-muted/70 truncate mt-0.5">{adv.description}</p>}
              </div>
              <div class="flex gap-0.5 shrink-0">
                <button type="button" class="edit-btn p-1.5 rounded-lg text-muted/40 hover:text-accent hover:bg-accent/10 transition-colors" data-id={adv.id}>
                  <svg class="h-4 w-4" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><path d="M17 3a2.85 2.83 0 1 1 4 4L7.5 20.5 2 22l1.5-5.5Z"/></svg>
                </button>
                <form method="POST">
                  <input type="hidden" name="_action" value="delete" />
                  <input type="hidden" name="adventure_id" value={adv.id} />
                  <button type="submit" class="p-1.5 rounded-lg text-muted/40 hover:text-red-400 hover:bg-red-50 transition-colors" onclick="return confirm('¿Eliminar esta aventura?')">
                    <svg class="h-4 w-4" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><path d="M3 6h18M19 6v14a2 2 0 0 1-2 2H7a2 2 0 0 1-2-2V6M8 6V4a2 2 0 0 1 2-2h4a2 2 0 0 1 2 2v2"/></svg>
                  </button>
                </form>
              </div>
            </div>
            {/* Edit mode */}
            <form method="POST" enctype="multipart/form-data" class="item-edit hidden px-4 py-3 space-y-3" data-id={adv.id}>
              <input type="hidden" name="_action" value="edit" />
              <input type="hidden" name="adventure_id" value={adv.id} />
              <div class="flex items-center justify-between mb-1">
                <p class="text-xs font-semibold text-accent">Editando</p>
                <button type="button" class="cancel-edit text-xs text-muted hover:text-ink" data-id={adv.id}>Cancelar</button>
              </div>
              <input type="text" name="title" value={adv.title} required placeholder="Título" class="w-full rounded-xl border border-card-border bg-canvas px-3 py-2 text-xs text-ink focus:outline-none focus:border-accent transition-colors" />
              <div class="grid grid-cols-2 gap-2">
                <input type="date" name="date" value={adv.date} required class="rounded-xl border border-card-border bg-canvas px-3 py-2 text-xs text-ink focus:outline-none focus:border-accent transition-colors" />
                <input type="text" name="location" value={adv.location || ''} placeholder="Lugar" class="rounded-xl border border-card-border bg-canvas px-3 py-2 text-xs text-ink focus:outline-none focus:border-accent transition-colors" />
              </div>
              <textarea name="description" rows="2" placeholder="Descripción" class="w-full rounded-xl border border-card-border bg-canvas px-3 py-2 text-xs text-ink focus:outline-none focus:border-accent transition-colors resize-none">{adv.description || ''}</textarea>
              <div>
                <label class="block text-[10px] text-muted mb-1">Cambiar foto (opcional)</label>
                <input type="file" name="photo" accept="image/*" class="w-full rounded-xl border border-card-border bg-canvas px-3 py-2 text-xs text-ink file:mr-2 file:rounded-md file:border-0 file:bg-accent/10 file:px-2 file:py-0.5 file:text-[10px] file:font-medium file:text-accent focus:outline-none" />
              </div>
              <button type="submit" class="w-full rounded-xl bg-accent text-white font-semibold py-2.5 text-xs hover:bg-accent-dark transition-colors active:scale-95">Guardar</button>
            </form>
          </div>
        ))}
      </div>
    </div>
  )}

  {/* ── LIGHTBOX ── */}
  <dialog
    id="lightbox"
    class="fixed inset-0 m-0 h-full w-full max-h-full max-w-full bg-transparent p-0 backdrop:bg-black/80 backdrop:backdrop-blur-sm"
  >
    <div class="flex h-full w-full items-center justify-center p-4">
      <div class="relative w-full max-w-lg">
        <button
          id="lightbox-close"
          type="button"
          class="absolute -top-12 right-0 flex h-10 w-10 items-center justify-center rounded-full bg-white/20 text-white transition-all hover:bg-white/30 active:scale-90"
          aria-label="Cerrar"
        >
          <svg class="h-5 w-5" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5"><path d="M18 6 6 18M6 6l12 12"/></svg>
        </button>
        <img id="lightbox-img" src="" alt="" class="w-full rounded-3xl object-contain max-h-screen shadow-2xl" />
        <div class="mt-3 text-center text-white">
          <p id="lightbox-title" class="font-semibold text-lg"></p>
          <p id="lightbox-meta" class="text-sm text-white/70 mt-0.5"></p>
          <p id="lightbox-desc" class="text-sm text-white/50 mt-1 max-w-sm mx-auto"></p>
        </div>
      </div>
    </div>
  </dialog>

  <script is:inline>
    document.addEventListener('astro:page-load', function() {
      // Edit / cancel
      document.querySelectorAll('.edit-btn').forEach(function(btn) {
        btn.addEventListener('click', function() {
          var id = btn.dataset.id;
          var view = document.querySelector('.item-view[data-id="' + id + '"]');
          var edit = document.querySelector('.item-edit[data-id="' + id + '"]');
          if (view) view.classList.add('hidden');
          if (edit) edit.classList.remove('hidden');
        });
      });
      document.querySelectorAll('.cancel-edit').forEach(function(btn) {
        btn.addEventListener('click', function() {
          var id = btn.dataset.id;
          var view = document.querySelector('.item-view[data-id="' + id + '"]');
          var edit = document.querySelector('.item-edit[data-id="' + id + '"]');
          if (view) view.classList.remove('hidden');
          if (edit) edit.classList.add('hidden');
        });
      });

      // Lightbox
      var lightbox = document.getElementById('lightbox');
      var img = document.getElementById('lightbox-img');
      var title = document.getElementById('lightbox-title');
      var meta = document.getElementById('lightbox-meta');
      var desc = document.getElementById('lightbox-desc');
      var closeBtn = document.getElementById('lightbox-close');

      document.querySelectorAll('.lightbox-trigger').forEach(function(btn) {
        btn.addEventListener('click', function() {
          var src = btn.dataset.src;
          if (!src || !lightbox || !img) return;
          img.src = src;
          img.alt = btn.dataset.title || '';
          if (title) title.textContent = btn.dataset.title || '';
          var parts = [btn.dataset.date, btn.dataset.location].filter(Boolean);
          if (meta) meta.textContent = parts.join(' · ');
          if (desc) desc.textContent = btn.dataset.description || '';
          lightbox.showModal();
          if ('vibrate' in navigator) navigator.vibrate(8);
        });
      });

      if (closeBtn && lightbox) closeBtn.addEventListener('click', function() { lightbox.close(); });
      if (lightbox) {
        lightbox.addEventListener('click', function(e) { if (e.target === lightbox) lightbox.close(); });
        lightbox.addEventListener('close', function() { if (img) img.src = ''; });
      }
    });
  </script>

  <p class="mt-10 mb-4 text-center text-xs text-muted/40 leading-relaxed max-w-xs mx-auto">Cada paseo, viaje o momento especial merece ser recordado. Sube fotos de las aventuras de {pet.name} y crea un álbum de recuerdos.</p>

</MainLayout>
